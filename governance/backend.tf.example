# Remote state backend (OPTIONAL). By default state is local. To use Azure Blob
# state with locking, rename this file to backend.tf and fill in the values (or
# pass them via `terraform init -backend-config=...`).
#
# Use a DISTINCT `key` from the terraform/ (cluster) module so they never share
# state. Governance state is management-group scoped and should be protected
# accordingly.
#
# terraform {
#   backend "azurerm" {
#     resource_group_name  = "rg-tfstate"
#     storage_account_name = "sttfstateexample"       # globally unique, 3-24 lowercase alnum
#     container_name       = "tfstate"
#     key                  = "aks-governance.tfstate"
#     use_azuread_auth     = true
#   }
# }
