# Copy this file to terraform.tfvars and set your management group.

# Required by azurerm 4.x (or export ARM_SUBSCRIPTION_ID instead).
subscription_id = "00000000-0000-0000-0000-000000000000"

# The management group NAME (for the tenant root MG, this is the tenant ID).
management_group_name = "mg-root"

# Optional overrides (defaults shown):
# identity_location       = "westeurope"
# assignment_name         = "aks-policy-addon"
# effect                  = "DeployIfNotExists"   # or "Disabled"
# create_remediation_task = true

# The two built-in roles the add-on DINE policy requires (change only if the
# built-in policy is revised):
# remediation_role_definition_ids = [
#   "ed7f3fbd-7b88-4dd4-9017-9adb7ce333f8", # Azure Kubernetes Service Contributor Role
#   "18ed5180-3e48-46fd-8541-4ea054d57064", # Azure Kubernetes Service Policy Add-on Deployment
# ]

# Pod-security-standards enforcement initiative:
# assign_security_baseline = true
# baseline_effect          = "Audit"            # or "Deny" to block non-compliant workloads
# Swap to the stricter "restricted" profile if desired:
# baseline_set_definition_id = "/providers/Microsoft.Authorization/policySetDefinitions/42b8ef37-b724-4e24-bbc8-7a7708edfe00"
# Add YOUR infra namespaces here before switching to Deny (defaults already cover
# kube-system, gatekeeper-system, azure-arc, azure-extensions-usage-system):
# baseline_excluded_namespaces = ["kube-system", "gatekeeper-system", "azure-arc", "azure-extensions-usage-system", "ingress-nginx"]
