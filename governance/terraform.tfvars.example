# Copy this file to terraform.tfvars and set your management group.

# Required by azurerm 4.x (or export ARM_SUBSCRIPTION_ID instead).
subscription_id = "00000000-0000-0000-0000-000000000000"

# The management group NAME (for the tenant root MG, this is the tenant ID).
management_group_name = "mg-root"

# Optional overrides (defaults shown):
# identity_location       = "westeurope"
# assignment_name         = "aks-policy-addon"
# effect                  = "DeployIfNotExists"   # or "Disabled"
# create_remediation_task = true
