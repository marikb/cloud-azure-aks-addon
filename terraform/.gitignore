# Local .terraform directories and plugin caches
.terraform/

# State files (should live in a remote backend, never in git)
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Variable files may contain secrets; commit only the example
*.tfvars
*.tfvars.json
!*.tfvars.example

# CLI config
.terraformrc
terraform.rc

# NOTE: .terraform.lock.hcl is intentionally NOT ignored — commit it to pin
# provider versions across machines.
